# StrixCamFake configuration

# Video sources (paths inside container or absolute paths)
MAIN_VIDEO=main.mp4
SUB_VIDEO=sub.mp4

# Credentials (used for RTSP auth, ONVIF, HTTP snapshots, web UI)
USERNAME=admin
PASSWORD=admin

# Server ports
RTSP_PORT=554
HTTP_PORT=80
RTMP_PORT=1935

# Camera identity (shown in ONVIF responses and web UI)
CAMERA_NAME=StrixCam
CAMERA_MODEL=SFC-2000
CAMERA_SERIAL=SFC-001
CAMERA_FIRMWARE=1.0.0

# Snapshot interval (how often to grab a JPEG frame from the stream)
SNAPSHOT_INTERVAL=5s
