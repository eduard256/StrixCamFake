# StrixCamFake configuration

# Video sources (paths inside container or absolute paths)
MAIN_VIDEO=main.mp4
SUB_VIDEO=sub.mp4

# Credentials (used for RTSP auth, ONVIF, HTTP snapshots, web UI)
USERNAME=admin
PASSWORD=admin

# Server ports
RTSP_PORT=554
HTTP_PORT=80
RTMP_PORT=1935
DVRIP_PORT=34568

# Camera identity (shown in ONVIF responses and web UI)
CAMERA_NAME=StrixCam
CAMERA_MODEL=SFC-2000
CAMERA_SERIAL=SFC-001
CAMERA_FIRMWARE=1.0.0

# Snapshot interval (how often to grab a JPEG frame from the stream)
SNAPSHOT_INTERVAL=5s

# ONVIF support.
# When true (default): /onvif/ SOAP endpoint is served and WS-Discovery
# responds on 239.255.255.250:3702 so the camera is auto-discoverable.
# When false: the endpoint is not registered and discovery is not started,
# so the camera looks like a device with no ONVIF support.
# Accepted values: true/false, 1/0, yes/no, on/off.
ONVIF_ENABLED=true
